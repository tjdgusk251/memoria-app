# ┌─────────────────────────────────────────────────────────────┐
# │ 이 파일은 '양식(예시)'입니다. 실제 값은 secrets.toml 에 넣으세요. │
# │ secrets.toml 은 .gitignore에 의해 커밋되지 않습니다(비밀 보호).  │
# └─────────────────────────────────────────────────────────────┘
#
# 로컬에서 클라우드 DB로 테스트하려면: 이 파일을 secrets.toml 로 복사하고 값을 채우세요.
# Streamlit Cloud 배포 시에는 파일 대신 앱 설정의 "Secrets" 칸에 아래 내용을 붙여넣으세요.

[turso]
url = "libsql://your-database-name-yourusername.turso.io"
token = "여기에-Turso-인증토큰-붙여넣기"
